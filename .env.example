# URL base de la API backend
VITE_API_URL=

# URL del servidor de websockets (socket.io). SIN /api — socket.io se monta en
# la raíz. Realtime de domain events (p. ej. fulfillment de envíos).
# Local: http://localhost:3000 · Prod: https://api.tudominio.com
VITE_WS_URL=

# Google Maps JavaScript API key (requires Maps JS API + Geometry library enabled)
VITE_GOOGLE_MAPS_API_KEY=
